{
  "$id": "dpsg-json",
  "title": "DPSG",
  "description": "",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[A-Za-zÄÖÜäöüß,\\- /.&]+$": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nummer"],
      "anyOf": [
        {"required": ["bezirke"]},
        {"required": ["staemme"]}
      ],
      "properties": {
        "nummer": {
          "type": "integer",
          "description": "Offizielle Nummer der Diözese"
        },
        "bezirke": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-zÄÖÜäöüß,\\- /.&]+$": {
              "type": "object",
              "additionalProperties": false,
              "required": ["nummer"],
              "properties": {
                "nummer": {
                  "type": "integer",
                  "description": "Offizielle Nummer des Bezirks in der Diözese"
                },
                "status": {
                  "type": "string",
                  "description": "Wird als aktiv angenommen, wenn nicht gesetzt",
                  "enum": ["aktiv", "unklar", "aufgelöst"]
                },
                "email": {
                  "type": "string"
                },
                "staemme": {
                  "type": "object",
                  "additionalProperties": false,
                  "patternProperties": {
                    "^[A-Za-zÄÖÜäöüßé0-9,\\- /.&()+]+$": {
                      "type": "object",
                      "required": ["typ"],
                      "additionalProperties": false,
                      "properties": {
                        "typ": {
                          "type": "string",
                          "enum": ["Stamm", "Siedlung"]
                        },
                        "ort": {
                          "type": "string",
                          "description": "Stadt o. Ä., an dem der Stamm seinen Sitz hat"
                        },
                        "nummer": {
                          "type": "integer",
                          "description": "Offizielle Nummer des Stammes im Bezirk / in der Diözese"
                        },
                        "stammesnummer": {
                          "type": "string",
                          "description": "Vollständige Stammesnummer (??/??/??), da deren Mittelteil nicht immer aus dem Bezirk zu ermitteln ist, wenn dieser fehlt"
                        },
                        "status": {
                          "type": "string",
                          "description": "Wird als aktiv angenommen, wenn nicht gesetzt",
                          "enum": ["aktiv", "unklar", "aufgeloest"]
                        },
                        "gruendungsjahr": {
                          "type": "integer",
                          "description": "Gründungsjahr, ggf. als Siedlung"
                        },
                        "email": {
                          "type": "string",
                          "description": "Email-Adresse für offiziellen Kontakt"
                        },
                        "web": {
                          "type": "string",
                          "description": "Vollständige Adresse der Website"
                        },
                        "quellen": {
                          "type": "array",
                          "description": "Array mit Web-Adressen, die als Quelle(n) herangezogen wurde(n)",
                          "items": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "staemme": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-zÄÖÜäöüßé0-9,\\- /.&()+]+$": {
              "type": "object",
              "required": ["typ"],
              "additionalProperties": false,
              "properties": {
                "typ": {
                  "type": "string",
                  "enum": ["Stamm", "Siedlung"]
                },
                "ort": {
                  "type": "string",
                  "description": "Stadt o. Ä., an dem der Stamm seinen Sitz hat"
                },
                "nummer": {
                  "type": "integer",
                  "description": "Offizielle Nummer des Stammes im Bezirk / in der Diözese"
                },
                "stammesnummer": {
                  "type": "string",
                  "description": "Vollständige Stammesnummer (??/??/??), da deren Mittelteil nicht immer aus dem Bezirk zu ermitteln ist, wenn dieser fehlt"
                },
                "status": {
                  "type": "string",
                  "description": "Wird als aktiv angenommen, wenn nicht gesetzt",
                  "enum": ["aktiv", "unklar", "aufgeloest"]
                },
                "gruendungsjahr": {
                  "type": "integer",
                  "description": "Gründungsjahr, ggf. als Siedlung"
                },
                "email": {
                  "type": "string",
                  "description": "Email-Adresse für offiziellen Kontakt"
                },
                "web": {
                  "type": "string",
                  "description": "Vollständige Adresse der Website"
                },
                "quellen": {
                  "type": "array",
                  "description": "Array mit Web-Adressen, die als Quelle(n) herangezogen wurde(n)",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
