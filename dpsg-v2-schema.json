{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "dpsg-json",
  "title": "DPSG",
  "description": "Validierung für eine maschinenlesbare Auflistung aller Gruppierungen der Deutschen Pfadfinderschaft Sankt Georg",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[A-Za-zÄÖÜäöüß,\\- /.&]+$": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nummer"],
      "anyOf": [
        {"required": ["bezirke"]},
        {"required": ["staemme"]}
      ],
      "properties": {
        "nummer": {
          "type": "integer",
          "description": "Offizielle Nummer der Diözese"
        },
        "gruendungsjahr": {
          "type": "integer",
          "description": "Gründungsjahr"
        },
        "web": {
          "type": "string",
          "description": "Vollständige Adresse der Website"
        },
        "bezirke": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-zÄÖÜäöüß,\\- /.&]+$": {
              "type": "object",
              "additionalProperties": false,
              "required": ["nummer"],
              "properties": {
                "nummer": {
                  "type": "integer",
                  "description": "Offizielle Nummer des Bezirks in der Diözese"
                },
                "bezirksnummer": {
                  "type": "string",
                  "description": "Vollständige Bezirksnummer (??/??/00), die bei einer Zusammenführung von Bezirken referenziert wird",
                  "pattern": "^[0-2]\\d./[0-2]\\d./00"
                },
                "status": {
                  "type": "string",
                  "description": "Wird als aktiv angenommen, wenn nicht gesetzt",
                  "enum": ["aktiv", "unklar", "zusammengefuehrt"]
                },
                "zusammengefuehrt_in": {
                  "type": "string",
                  "description": "Bezirksnummer, in die der Bezirk zusammengeführt wurde",
                  "pattern": "^[0-2]\\d./[0-2]\\d./00"
                },
                "gruendungsjahr": {
                  "type": "integer",
                  "description": "Gründungsjahr"
                },
                "email": {
                  "type": "string"
                },
                "web": {
                  "type": "string",
                  "description": "Vollständige Adresse der Website"
                },
                "staemme": {
                  "type": "object",
                  "additionalProperties": false,
                  "patternProperties": {
                    "^[A-Za-zÄÖÜäöüßé0-9,\\- /.&()+]+$": {
                      "type": "object",
                      "required": ["typ", "nummer", "stammesnummer"],
                      "additionalProperties": false,
                      "properties": {
                        "typ": {
                          "type": "string",
                          "enum": ["Stamm", "Siedlung"]
                        },
                        "ort": {
                          "type": "string",
                          "description": "Stadt o. Ä., an dem der Stamm seinen Sitz hat"
                        },
                        "nummer": {
                          "type": "integer",
                          "description": "Offizielle Nummer des Stammes im Bezirk / in der Diözese"
                        },
                        "stammesnummer": {
                          "type": "string",
                          "description": "Vollständige Stammesnummer (??/??/??), da deren Mittelteil nicht immer aus dem Bezirk zu ermitteln ist, wenn dieser fehlt",
                          "pattern": "^[0-3]\\d./[0-6]\\d./\\d\\d"
                        },
                        "alte_stammesnummern": {
                          "type": "array",
                          "description": "Array mit früheren Stammesnummern",
                          "items": {
                            "type": "string",
                            "pattern": "^[0-3]\\d./[0-6]\\d./\\d\\d"
                          }
                        },
                        "status": {
                          "type": "string",
                          "description": "Wird als aktiv angenommen, wenn nicht gesetzt",
                          "enum": ["aktiv", "unklar", "aufgeloest"]
                        },
                        "gruendungsjahr": {
                          "type": "integer",
                          "description": "Gründungsjahr, ggf. als Siedlung"
                        },
                        "email": {
                          "type": "string",
                          "description": "Email-Adresse für offiziellen Kontakt"
                        },
                        "web": {
                          "type": "string",
                          "description": "Vollständige Adresse der Website"
                        },
                        "quellen": {
                          "type": "array",
                          "description": "Array mit Web-Adressen, die als Quelle(n) herangezogen wurde(n)",
                          "items": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "staemme": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-zÄÖÜäöüßé0-9,\\- /.&()+]+$": {
              "type": "object",
              "required": ["typ", "nummer", "stammesnummer"],
              "additionalProperties": false,
              "properties": {
                "typ": {
                  "type": "string",
                  "enum": ["Stamm", "Siedlung"]
                },
                "ort": {
                  "type": "string",
                  "description": "Stadt o. Ä., an dem der Stamm seinen Sitz hat"
                },
                "nummer": {
                  "type": "integer",
                  "description": "Offizielle Nummer des Stammes im Bezirk / in der Diözese"
                },
                "stammesnummer": {
                  "type": "string",
                  "description": "Vollständige Stammesnummer (??/??/??), da deren Mittelteil nicht immer aus dem Bezirk zu ermitteln ist, wenn dieser fehlt",
                  "pattern": "^[0-3]\\d./[0-6]\\d./\\d\\d"
                },
                "alte_stammesnummern": {
                  "type": "array",
                  "description": "Array mit früheren Stammesnummern",
                  "items": {
                    "type": "string",
                    "pattern": "^[0-3]\\d./[0-6]\\d./\\d\\d"
                  }
                },
                "status": {
                  "type": "string",
                  "description": "Wird als aktiv angenommen, wenn nicht gesetzt",
                  "enum": ["aktiv", "unklar", "aufgeloest"]
                },
                "gruendungsjahr": {
                  "type": "integer",
                  "description": "Gründungsjahr, ggf. als Siedlung"
                },
                "email": {
                  "type": "string",
                  "description": "Email-Adresse für offiziellen Kontakt"
                },
                "web": {
                  "type": "string",
                  "description": "Vollständige Adresse der Website"
                },
                "quellen": {
                  "type": "array",
                  "description": "Array mit Web-Adressen, die als Quelle(n) herangezogen wurde(n)",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
